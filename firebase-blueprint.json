{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A menu item in the cafe.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "averageRating": { "type": "number" }
      },
      "required": ["name", "price", "category"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a product.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "text": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["productId", "userId", "userName", "rating", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "specialInstruction": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "object" }
        },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "userName", "phoneNumber", "address", "items", "total", "status", "createdAt"]
    },
    "UserRole": {
      "title": "UserRole",
      "description": "User roles for RBAC.",
      "type": "object",
      "properties": {
        "role": { "type": "string" }
      },
      "required": ["role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Stores products"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Stores reviews for a specific product"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores user orders"
    },
    "/userRoles/{userId}": {
      "schema": { "$ref": "#/entities/UserRole" },
      "description": "Stores user roles, used to determine admin access"
    }
  }
}
